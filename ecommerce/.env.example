# Copy this file to .env and fill in real values before running.

# MySQL connection
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=shopkart
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=shopkart
MYSQL_ROOT_PASSWORD=change_me_root

# Full SQLAlchemy URL (used directly by the app)
DATABASE_URL=mysql+pymysql://shopkart:change_me@db:3306/shopkart

# Auth
SECRET_KEY=change_this_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# App
ENVIRONMENT=development
SEED_DEMO_DATA=true
